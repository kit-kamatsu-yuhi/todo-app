{
  "strict": {
    "label": "厳格モード（Strict）",
    "description": "全セキュリティ設定を有効化。ネットワークはホワイトリスト方式。",
    "settings": {
      "permissions": {
        "deny": [
          "Bash(terraform destroy*)",
          "Bash(terraform apply*)",
          "Bash(terraform import*)",
          "Bash(terraform state rm*)",
          "Bash(terraform taint*)",
          "Bash(terraform untaint*)",
          "Bash(rm -rf *)",
          "Bash(git push --force*)",
          "Bash(git push -f*)",
          "Bash(chmod 777 *)",
          "Bash(chmod -R 777 *)",
          "Bash(gcloud * delete*)",
          "Bash(gcloud projects delete*)",
          "Bash(gcloud storage rm*)",
          "Bash(gcloud storage buckets delete*)",
          "Bash(gcloud iam service-accounts delete*)",
          "Bash(aws * delete*)",
          "Bash(aws * terminate*)",
          "Bash(aws s3 rb*)",
          "Bash(aws s3 rm*)",
          "Bash(aws iam delete*)",
          "Bash(curl *)",
          "Bash(wget *)",
          "Bash(ssh *)",
          "Bash(nc *)",
          "Bash(ncat *)",
          "Bash(socat *)",
          "Bash(scp *)",
          "Bash(rsync *://*)",
          "Bash(python -m http.server*)",
          "Bash(python3 -m http.server*)",
          "Bash(node -e*)",
          "Bash(eval *)",
          "Bash(base64 -d*)",
          "Bash(dd if=*)",
          "Bash(mkfs*)",
          "Bash(mount *)",
          "Bash(umount *)",
          "Bash(kill -9 *)",
          "Bash(killall *)",
          "Bash(pkill *)",
          "Bash(sudo *)",
          "Bash(su *)",
          "Bash(chown *)",
          "Bash(chgrp *)",
          "Bash(setfacl *)",
          "Bash(iptables *)",
          "Bash(docker run*)",
          "Bash(docker exec*)",
          "Bash(kubectl exec*)",
          "Bash(kubectl delete*)",
          "Read(**/.env*)",
          "Read(**/*.pem)",
          "Read(**/*.key)",
          "Read(**/*.p12)",
          "Read(**/*.pfx)",
          "Read(**/credentials*)",
          "Read(**/secrets*)",
          "Read(**/.aws/*)",
          "Read(**/.ssh/*)",
          "Read(**/.gnupg/*)"
        ]
      },
      "sandbox": {
        "enabled": true,
        "allowUnsandboxedCommands": false,
        "network": {
          "allowedDomains": [
            "github.com",
            "api.github.com",
            "npmjs.org",
            "registry.npmjs.org",
            "pypi.org",
            "files.pythonhosted.org",
            "pkg.go.dev",
            "proxy.golang.org",
            "crates.io",
            "rubygems.org"
          ]
        }
      }
    }
  },
  "standard": {
    "label": "標準モード（Standard）",
    "description": "バランスの取れたセキュリティ設定。現在のデフォルトに近い。",
    "settings": {
      "permissions": {
        "deny": [
          "Bash(terraform destroy*)",
          "Bash(terraform apply*)",
          "Bash(terraform import*)",
          "Bash(terraform state rm*)",
          "Bash(terraform taint*)",
          "Bash(terraform untaint*)",
          "Bash(rm -rf *)",
          "Bash(git push --force*)",
          "Bash(git push -f*)",
          "Bash(chmod 777 *)",
          "Bash(chmod -R 777 *)",
          "Bash(gcloud * delete*)",
          "Bash(gcloud projects delete*)",
          "Bash(gcloud storage rm*)",
          "Bash(gcloud storage buckets delete*)",
          "Bash(gcloud iam service-accounts delete*)",
          "Bash(aws * delete*)",
          "Bash(aws * terminate*)",
          "Bash(aws s3 rb*)",
          "Bash(aws s3 rm*)",
          "Bash(aws iam delete*)",
          "Bash(curl *)",
          "Bash(wget *)",
          "Bash(ssh *)",
          "Read(**/.env*)",
          "Read(**/*.pem)"
        ]
      },
      "sandbox": {
        "enabled": true
      }
    }
  },
  "relaxed": {
    "label": "緩和モード（Relaxed）",
    "description": "最小限のセキュリティ制限。信頼された環境向け。",
    "settings": {
      "permissions": {
        "deny": [
          "Bash(rm -rf /)",
          "Bash(rm -rf /*)",
          "Bash(terraform destroy*)",
          "Bash(dd if=/dev/zero*)",
          "Bash(mkfs*)",
          "Bash(:(){ :|:& };:*)"
        ]
      },
      "sandbox": {
        "enabled": false
      }
    }
  }
}
