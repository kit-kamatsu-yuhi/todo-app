# auto-dev 環境変数
# このファイルをコピーして .env.agent を作成する:
#   cp .env.example .env.agent

# === 必須 ===

# GitHub Personal Access Token (repo, issues, pull-requests scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 対象リポジトリ (owner/repo)
AUTO_DEV_REPO=your-org/your-repo

# === Claude 認証（推奨: コンテナ起動後に対話 OAuth ログイン）===
#
# auto-dev は subscription OAuth login を default に設計されている。
# 起動後に以下で /login すると entrypoint.sh が自動検知してポーリング開始する:
#
#   1. docker compose up -d
#   2. docker exec -it -u autodev <container> claude
#   3. REPL で /login を実行（v2.1.114 以降は subcommand 廃止、スラッシュコマンド）
#
# API key 不要・定額・キャッシュも効く。subscription を持っているならこちらを使う。

# === Claude API key 認証（代替：subscription を持っていない場合のみ）===
#
# 上の OAuth login を使う場合は以下を未設定のまま、空のままにすること。
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Codex CLI 認証（claude と同じく login が default、API key は代替）===
#
# /codex-team を使うなら codex CLI も login しておく。利用可能なモデルは認証方式
# （subscription / API key）に依存し、codex CLI の default（最新）が使われる。
#
#   1. docker compose up -d（コンテナを起動）
#   2. docker exec -it -u autodev <container> codex login
#      → 表示される URL を host のブラウザで開いて OAuth 認証
#   3. completion 後 codex exec が使えるようになる
#
# subscription を持っていない場合は OPENAI_API_KEY を設定して key 認証する。
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === オプション ===

# ポーリング間隔（秒）。HEARTBEAT_INTERVAL の整数倍にすること
AUTO_DEV_POLL_INTERVAL=300

# ハートビート間隔（秒）。short I/O で WSL idle を抑止する
AUTO_DEV_HEARTBEAT_INTERVAL=30

# 処理対象の Issue ラベル
AUTO_DEV_ISSUE_LABEL=auto-dev

# Claude CLI 最大ターン数（1 Issue あたり）
AUTO_DEV_MAX_TURNS=200

# 1 Issue あたりの予算上限（USD、API key 認証時のみ機能）
AUTO_DEV_MAX_BUDGET_USD=5.00

# 1日あたりの予算上限（USD、API key 認証時のみ機能）
AUTO_DEV_DAILY_BUDGET_USD=50.00

# Worker タイムアウト（秒）
AUTO_DEV_WORKER_TIMEOUT=1800

# ログ保持日数
AUTO_DEV_LOG_RETENTION_DAYS=1

# Slack Webhook URL（通知を送る場合）
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Codex CLI の自前 sandbox (bubblewrap) を無効化する
# Docker コンテナ内では user namespace 作成が拒否されて exec 全敗するため none が必要
CODEX_SANDBOX=none
