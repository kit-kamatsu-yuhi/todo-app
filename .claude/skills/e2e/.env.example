# E2E skill environment variables (configure for your project)
#
# --- Backend selection ---
E2E_BACKEND=agent-browser
# E2E_BACKEND=chrome-devtools
#
# --- Target URLs ---
E2E_BASE_URL=https://staging.example.com
# Multi-app projects can add their own URL vars here (e.g. E2E_ADMIN_BASE_URL=..., E2E_API_BASE_URL=...).
#
# --- Test credentials (DO NOT COMMIT real values) ---
# Required: project test account email
E2E_LOGIN_EMAIL=
E2E_LOGIN_PASSWORD=
#
# --- Optional: Claude model override (leave blank to use CLI default) ---
CLAUDE_MODEL=
#
# --- Optional: Google Cloud project for Vertex AI (leave blank to use gcloud default) ---
GOOGLE_CLOUD_PROJECT=
CLOUD_ML_REGION=global
