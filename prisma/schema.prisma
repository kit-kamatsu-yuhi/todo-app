// Issue #7: 接続確立のみ。業務モデル（User/Todo 等）は #8 で追加する。
// Issue #8: User / Todo テーブルを追加する。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  createdAt      DateTime       @default(now())
  todos          Todo[]
  sessions       Session[]
  todoCategories TodoCategory[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Todo {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  completed  Boolean       @default(false)
  position   Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  categoryId String?
  category   TodoCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // 同一ユーザー内で position の重複を DB レベルで防止する
  @@unique([userId, position])
  // SQLite は FK インデックスを自動生成しないため明示的に追加する
  @@index([userId])
  @@index([categoryId])
}

model TodoCategory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 同名カテゴリの重複は Issue 要件外のため許容する（一意制約なし）
  name      String
  createdAt DateTime @default(now())
  todos     Todo[]

  @@index([userId])
}
